{
  "config": {
    "step": {
      "user": {
        "title": "NIO integration",
        "description": "Choose what to connect. Vehicle status and battery-swap history use different API endpoints — add them separately. Vehicle can run on its own; swap history is optional.",
        "menu_options": {
          "vehicle": "Vehicle status",
          "change": "Battery swap / service orders (optional)"
        }
      },
      "vehicle": {
        "title": "Connect your NIO vehicle",
        "description": "Sniff one vehicle-status request from the NIO app (MITM proxy: icar.nio.com/api/2/rvs/vehicle/.../status) and paste the whole request URL below, plus its Authorization Bearer token. The URL is replayed exactly as captured — don't edit it.",
        "data": {
          "capture": "Captured status request URL (the whole .../status?... line)",
          "token": "Bearer token (Authorization header)",
          "model": "Vehicle model"
        }
      },
      "change": {
        "title": "Connect NIO service orders",
        "description": "Sniff the getTabOrder request from Postman or the NIO app (gateway-front-external.nio.com/.../serviceOrder/getTabOrder?...). Paste the full URL (POST with query params is typical), Bearer token, and Cookie if your capture includes it.",
        "data": {
          "capture": "Captured getTabOrder request URL",
          "token": "Bearer token (Authorization header)",
          "change_name": "Display name",
          "cookie": "Cookie header (optional)",
          "change_method": "HTTP method"
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate NIO",
        "description": "Paste a fresh Bearer token. If the signature was rejected (vehicle) or the URL changed, also paste a newly captured request URL.",
        "data": {
          "token": "Bearer token (Authorization header)",
          "capture": "Captured request URL (optional — only if re-sniffed)",
          "cookie": "Cookie header (optional, service orders only)"
        }
      }
    },
    "error": {
      "invalid_auth": "The NIO API rejected the token. Re-sniff a fresh Bearer token.",
      "invalid_sign": "The NIO API rejected the signature, not the token — re-sniff a current vehicle status request.",
      "invalid_url": "Couldn't parse that as a vehicle status request. Paste the whole .../status?...&sign=... line.",
      "invalid_change_url": "Couldn't parse that as a service-order request. Paste the getTabOrder URL with query params.",
      "cannot_connect": "Could not reach the NIO API."
    },
    "abort": {
      "already_configured": "This entry is already configured.",
      "reauth_successful": "Re-authentication was successful."
    }
  },
