{
  "config": {
    "step": {
      "user": {
        "title": "NIO 集成",
        "description": "选择要连接的内容。车辆状态与换电/服务订单使用不同的 API，需要分别添加。车辆信息可单独运行；换电记录为可选项。",
        "menu_options": {
          "vehicle": "车辆状态",
          "change": "换电 / 服务订单（可选）"
        }
      },
      "vehicle": {
        "title": "连接你的蔚来汽车",
        "description": "用抓包工具嗅探 NIO App 的一次车辆状态请求（icar.nio.com/api/2/rvs/vehicle/.../status），在下方三个输入框中填写 URL、Token 和车型。URL 会被原样重放，请勿改动。",
        "data": {
          "capture": "状态请求 URL",
          "token": "Bearer Token",
          "model": "车型"
        },
        "data_description": {
          "capture": "粘贴整条 .../status?...&sign=... 请求 URL",
          "token": "粘贴 Authorization 头里的 Bearer token",
          "model": "例如 EC6、ES6、ET5"
        }
      },
      "change": {
        "title": "连接蔚来服务订单",
        "description": "从 Postman 或 NIO App 抓取 getTabOrder 请求，在下方填写 URL、Token 等信息。",
        "data": {
          "capture": "getTabOrder 请求 URL",
          "token": "Bearer Token",
          "change_name": "显示名称",
          "cookie": "Cookie（可选，多数 Postman 抓包没有）",
          "change_user_agent": "User-Agent（可选）",
          "change_mobileinfo": "mobileinfo（可选，App 抓包才有）",
          "change_method": "HTTP 方法"
        },
        "data_description": {
          "capture": "Postman 地址栏完整 URL（含 Params 全部参数，limit=2000 等）",
          "token": "Authorization 标签页里的 Bearer token",
          "cookie": "仅当 Headers 里有 Cookie 时才填，没有可留空",
          "change_user_agent": "可选，Postman 一般为 PostmanRuntime/..."
        }
      },
      "reauth_confirm": {
        "title": "重新认证 NIO",
        "description": "粘贴新的 Bearer token。若是签名被拒（车辆）或 URL 变更，再粘贴一条新抓的请求 URL。",
        "data": {
          "token": "Bearer token（Authorization 头）",
          "capture": "抓到的请求 URL（可选——仅在重新抓包时填）",
          "cookie": "Cookie 头（可选，仅服务订单）"
        }
      }
    },
    "error": {
      "invalid_auth": "NIO API 拒绝了该 token。请重新抓一个新的 Bearer token。",
      "invalid_sign": "NIO API 拒绝的是签名、不是 token——请重新抓一次当前的状态请求。",
      "invalid_url": "无法识别为车辆状态请求。请把包含 /vehicle/.../status?...&sign=... 的整行粘进来。",
      "invalid_change_url": "无法识别为服务订单请求。请粘贴带 query 参数的 getTabOrder URL。",
      "empty_orders": "接口已连通但返回 0 条订单。请检查 Cookie（Postman 里的 tgw_l7_route=...）、URL 和 Token 是否与抓包一致。",
      "cannot_connect": "无法连接 NIO API。"
    },
    "abort": {
      "already_configured": "该配置已存在。",
      "reauth_successful": "重新认证成功。"
    }
